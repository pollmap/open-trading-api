# KIS Backtest MCP Server 환경변수 예시
# cp .env.example .env 후 실제 값으로 수정

MCP_PORT=3846
MCP_HOST=127.0.0.1
LEAN_WORKSPACE=/tmp/lean_workspace

# ── Luxon Intelligence (로컬 LLM + MCP 브리지) ─────────────────────
# 자동 로드: kis_backtest.luxon.intelligence import 시 .env 자동 로드.
# 시스템 env 우선 (이미 설정돼있으면 .env 값 무시).

# Nexus Finance MCP (VPS) Bearer 토큰 — 필수
MCP_VPS_TOKEN=

# MCP 엔드포인트 오버라이드 (선택)
# KIS_BACKTEST_MCP_URL=http://127.0.0.1:3846
# NEXUS_MCP_URL=https://62.171.141.206:8100
# DRAWIO_MCP_URL=http://127.0.0.1:8420

# LLM 엔드포인트 오버라이드 (선택)
# LUXON_LLM_FAST_URL=http://127.0.0.1:52625/v1
# LUXON_LLM_DEFAULT_URL=http://127.0.0.1:11434
# LUXON_LLM_HEAVY_URL=http://127.0.0.1:11434
# LUXON_LLM_LONG_URL=http://127.0.0.1:5001/v1

# ── KIS Open API (v1.0 STEP 6) ────────────────────────────────────
# 권장: ~/KIS/config/kis_devlp.yaml 사용. 아래 환경변수는 대안.
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=
# KIS_HTS_ID=
# KIS_MODE=paper                # paper | live

# ── Luxon 런타임 ──────────────────────────────────────────────────
LUXON_HOME=~/.luxon
LUXON_LOG_LEVEL=INFO
LUXON_CAPITAL=10000000
LUXON_PAPER_MODE=true
LUXON_KIS_PAPER=true
# LUXON_CUFA_DIGESTS_DIR=

# Windows cp949 방지 (필수)
PYTHONIOENCODING=utf-8
